# Agentics
## Memory persistance path
AGENT_PERSISTANCE_PATH=/tmp/agentic_memory
## CrewAI
CREWAI_DISABLE_TELEMETRY=1

# Model Providers
## WatsonX AI
MODEL_ID=watsonx/openai/gpt-oss-120b
WATSONX_URL=https://us-south.ml.cloud.ibm.com 
WATSONX_APIKEY=YOURS
WATSONX_PROJECTID=YOURS

## OpenAI credentials (Optional)
OPENAI_API_KEY="Your_OpenAI_API_KEY"
OPENAI_MODEL_ID="openai/gpt-4"

## VLLM (Optional)
VLLM_URL=<http://base_url:PORT/v1>
VLLM_MODEL_ID="hosted_vllm/meta-llama/Llama-3.3-70B-Instruct"

## OLLAMA (Optional)
OLLAMA_MODEL_ID="ollama/deepseek-r1:latest"
OLLAMA_URL="http://localhost:11434"

# Applications
## BIRD
BIRD_PATH=<path to bird-bench sqlite db/BIRD>
