FROM flink:1.18.1-scala_2.12-java11

# Install Python and dependencies
USER root

# Install Python, JDK headers, build tools, and git
RUN apt-get update && \
    apt-get install -y python3 python3-pip python3-dev openjdk-11-jdk-headless build-essential curl git && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install uv package manager
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Copy Java include directory for pemja
RUN cp -r /usr/lib/jvm/java-11-openjdk-*/include /opt/java/openjdk/

# Install PyFlink
ENV JAVA_HOME=/opt/java/openjdk
ENV PATH="/root/.local/bin:$PATH"
RUN uv pip install --system apache-flink==1.18.1

# Install essential dependencies for agentics core (excluding heavy/unnecessary ones)
RUN uv pip install --system \
    pydantic \
    openai \
    litellm \
    'crewai[tools]' \
    loguru \
    langchain-core \
    langchain-openai \
    langchain-huggingface \
    python-dotenv \
    pyyaml \
    json-schema-to-pydantic \
    fastavro \
    async-lru \
    rich \
    jsonfinder \
    ddgs \
    numerize

# Copy agentics core modules (without installing the full package)
COPY src/agentics /opt/flink/agentics
ENV PYTHONPATH=/opt/flink:$PYTHONPATH

# Create UDF directory
RUN mkdir -p /opt/flink/udfs

# Copy UDF files
COPY tools/agstream_manager/udfs/ /opt/flink/udfs/

# Add Python configuration to Flink (clean file first to avoid duplicates)
RUN grep -v "python.executable" /opt/flink/conf/flink-conf.yaml > /tmp/flink-conf-clean.yaml && \
    mv /tmp/flink-conf-clean.yaml /opt/flink/conf/flink-conf.yaml && \
    echo 'python.executable: /usr/bin/python3' >> /opt/flink/conf/flink-conf.yaml && \
    echo 'python.client.executable: /usr/bin/python3' >> /opt/flink/conf/flink-conf.yaml && \
    echo 'python.files: /opt/flink/udfs' >> /opt/flink/conf/flink-conf.yaml

# Ensure Python is executable by all users and set proper permissions
RUN chmod 755 /usr/bin/python3 && \
    chmod 755 /usr/bin/python3.10 && \
    chmod -R 755 /usr/lib/python3.10 && \
    chmod -R 755 /usr/local/lib/python3.10 && \
    chmod -R 755 /opt/flink/udfs

# Make sure flink user can access everything
RUN chown -R flink:flink /opt/flink/udfs

# Switch back to flink user
USER flink

# Set Python path and ensure it's in PATH
ENV PYTHONPATH=/opt/flink/udfs:$PYTHONPATH
ENV PATH=/usr/bin:$PATH
