# AGStream Manager Configuration Example
# Copy this file to .env and customize as needed

# ============================================================================
# CrewAI Configuration (Performance Optimization)
# ============================================================================

# Disable CrewAI tracing and telemetry to prevent 20-second delays in Flink UDFs
# These are automatically set by the agentics library, but can be overridden here
CREWAI_TRACING_ENABLED=false
CREWAI_DISABLE_TELEMETRY=true
CREWAI_DISABLE_TRACING=true
CREWAI_TELEMETRY=false
OTEL_SDK_DISABLED=true
CREWAI_TRACING_DISABLED=true
CREWAI_SILENT=true
CREWAI_STORAGE_DIR=/tmp/crewai
CREWAI_ALLOW_STACK_TRACES=false

# ============================================================================
# UDF Configuration
# ============================================================================

# Path to the directory containing Python UDF files
# Can be relative (to agstream_manager directory) or absolute
UDF_FOLDER=udfs

# Examples of alternative UDF folders:
# UDF_FOLDER=custom_udfs                    # Relative path
# UDF_FOLDER=../../../my_project/udfs       # Relative path to another project
# UDF_FOLDER=/absolute/path/to/udfs         # Absolute path

# ============================================================================
# AGStream Backends Directory
# ============================================================================

# Directory for storing Kafka data and saved functions
# This directory will be created if it doesn't exist
AGSTREAM_BACKENDS=./agstream-backends

# ============================================================================
# Schema Registry Configuration
# ============================================================================

# URL for Karapace Schema Registry
# Use karapace-schema-registry:8081 from within Docker containers
# Use localhost:8081 from host machine
SCHEMA_REGISTRY_URL=http://karapace-schema-registry:8081

# ============================================================================
# Auto-install Configuration
# ============================================================================

# Set to "true" to automatically install Agentics and UDFs when Flink starts
# Set to "false" to disable auto-installation (manual installation required)
# Note: Installation is skipped if Agentics is already present (smart caching)
# To force reinstall: cd scripts && ./install_agentics_in_flink.sh --force
AUTO_INSTALL_ON_STARTUP=true

# ============================================================================
# Flink Container Names
# ============================================================================

# Usually you don't need to change these unless you've customized docker-compose
FLINK_JOBMANAGER_CONTAINER=flink-jobmanager
FLINK_TASKMANAGER_CONTAINER=flink-taskmanager

# ============================================================================
# Fake Instance Generation Configuration
# ============================================================================

# Maximum number of instances that can be generated in a single API request
# Default: 100
# Increase this if you need to generate more instances at once
MAX_GENERATE_INSTANCES=100

# ============================================================================
# Flink SQL Parallelism Configuration
# ============================================================================

# Default parallelism for Flink SQL queries
# This controls how many parallel tasks Flink uses for SQL operations
# Default: 4
# Recommended values:
#   - 1:  Single-threaded (debugging)
#   - 4:  Small workloads
#   - 10: Medium workloads
#   - 20: Large workloads
#   - 50: Very large workloads
# Note: Should match or be less than Kafka topic partitions and TaskManager slots
FLINK_SQL_PARALLELISM=4

# ============================================================================
# Usage Notes
# ============================================================================

# 1. UDF Directory Structure:
#    - Place all your Python UDF files in the UDF_FOLDER directory
#    - All .py files in this directory will be automatically copied to Flink
#    - UDFs must follow PyFlink UDF conventions (use @udf decorator)
#
# 2. Auto-installation:
#    - When AUTO_INSTALL_ON_STARTUP=true, both Agentics and UDFs are installed
#      automatically when you run: ./manage_services_full.sh start
#    - This happens after Flink containers start (after 20 second wait)
#    - If installation fails, you can still install manually
#
# 3. Manual Installation:
#    - Agentics: cd scripts && ./install_agentics_in_flink.sh
#    - UDFs: cd scripts && ./install_udfs.sh
#
# 4. After Installation:
#    - UDFs must still be registered in each Flink SQL session
#    - Example: CREATE TEMPORARY SYSTEM FUNCTION my_func AS 'my_udfs.my_func' LANGUAGE PYTHON;
